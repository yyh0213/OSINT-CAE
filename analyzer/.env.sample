# ============================================================
#  OSINT Dashboard 환경 변수 설정 파일
#  cp .env.example .env 후 실제 값을 채워주세요
# ============================================================

# [필수] OpenRouter AI API 키
OPENROUTER_API_KEY=sk-or-v1-**************************

# [필수] Qdrant / Ollama가 돌아가는 서버 IP
DB_IP=192.168.0.0

# [선택] Discord 알림 (없으면 알림 비활성화)
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/...
DISCORD_USER_ID=1234

# [선택] Discord 알림에 포함될 대시보드 접속 주소
#  - 로컬: http://localhost:8000
#  - Unraid: http://192.168.0.0:8080
DASHBOARD_URL=http://192.168.0.0:8080

# [선택] 보고서 저장 경로 (컨테이너 내부 경로, 기본값 그대로 두면 됨)
REPORT_DIR=/app/OSINT_REPORT

# [선택] reliability.db 경로
#  - 로컬(Windows) 직접 실행 시: 자동으로 ../intelligence/config/reliability.db 를 사용
#  - Docker 실행 시: 컨테이너 내부 마운트 경로를 명시해주세요
#    예) RELIABILITY_DB_PATH=/app/intelligence/config/reliability.db
RELIABILITY_DB_PATH=/app/intelligence/config/reliability.db
